local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local GuiService = game:GetService("GuiService")
local Workspace = game:GetService("Workspace")
local CoreGui = game:GetService("CoreGui")

local Player = Players.LocalPlayer
local os_time = os.time()

-- ═══════════════════════════════════════════════════════════
--  EXTREME GRAPHICS OPTIMIZER (optimized batch processing)
-- ═══════════════════════════════════════════════════════════

-- Pre-cache class checks to avoid repeated string comparisons
local DISABLE_CLASSES = {
    ParticleEmitter = true, Trail = true, Beam = true,
    Fire = true, Smoke = true, Sparkles = true,
}

local HIDE_CLASSES = {
    Decal = true, Texture = true,
}

local POST_EFFECT_CLASSES = {
    BlurEffect = true, BloomEffect = true, SunRaysEffect = true,
    ColorCorrectionEffect = true, DepthOfFieldEffect = true,
    Atmosphere = true, Sky = true,
}

local function optimizePart(obj)
    local className = obj.ClassName
    
    -- BasePart optimization
    if obj:IsA("BasePart") then
        obj.CastShadow = false
        obj.Material = Enum.Material.SmoothPlastic
        obj.Reflectance = 0
        return
    end
    
    -- Disable particle effects
    if DISABLE_CLASSES[className] then
        obj.Enabled = false
        pcall(function() obj.Rate = 0 end)
        return
    end
    
    -- Hide decals/textures
    if HIDE_CLASSES[className] then
        obj.Transparency = 1
        return
    end
    
    -- Strip clothing textures (don't destroy to avoid game checks)
    if className == "Shirt" then
        pcall(function() obj.ShirtTemplate = "" end)
    elseif className == "Pants" then
        pcall(function() obj.PantsTemplate = "" end)
    elseif className == "ShirtGraphic" then
        pcall(function() obj.Graphic = "" end)
    end
    
    -- Mute sounds
    if obj:IsA("Sound") then
        obj.MaxDistance = 0
        obj.Volume = 0
    end
end

local function optimizeGraphics()
    pcall(function()
        -- 1. Game Settings
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        settings().Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level04
        pcall(function() sethiddenproperty(Lighting, "Technology", 2) end)

        -- 2. Lighting
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.Brightness = 0
        Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
        Lighting.ClockTime = 12

        -- 3. Remove post effects
        for _, effect in ipairs(Lighting:GetChildren()) do
            if POST_EFFECT_CLASSES[effect.ClassName] or effect:IsA("PostEffect") then
                effect:Destroy()
            end
        end

        -- 4. Terrain
        local terrain = Workspace:FindFirstChildOfClass("Terrain")
        if terrain then
            terrain.WaterWaveSize = 0
            terrain.WaterWaveSpeed = 0
            terrain.WaterReflectance = 0
            terrain.WaterTransparency = 1
            terrain.Decoration = false
        end

        -- 5. Batch optimize all descendants (yield every 1000 to prevent freeze)
        local descendants = Workspace:GetDescendants()
        local count = #descendants
        for i = 1, count do
            pcall(optimizePart, descendants[i])
            -- Yield less frequently (1000 instead of 500) — reduces overhead
            if i % 1000 == 0 then RunService.Heartbeat:Wait() end
        end

        -- 6. Auto-optimize new objects (debounced)
        Workspace.DescendantAdded:Connect(function(obj)
            -- Small delay to let object initialize before modifying
            task.defer(function()
                pcall(optimizePart, obj)
            end)
        end)
    end)
end

-- ═══════════════════════════════════════════════════════════
--  FPS COUNTER UI (optimized — update every 1s instead of 0.5s)
-- ═══════════════════════════════════════════════════════════

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "CynxFPS"
screenGui.Parent = pcall(function() return CoreGui end) and CoreGui or Player:WaitForChild("PlayerGui")
screenGui.DisplayOrder = 999999999
screenGui.ResetOnSpawn = false

local frame = Instance.new("Frame")
frame.Parent = screenGui
frame.Size = UDim2.new(0, 200, 0, 36)
frame.Position = UDim2.new(0, 8, 0, 8)
frame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
frame.BackgroundTransparency = 0.3
frame.BorderSizePixel = 0

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = frame

local fpsLabel = Instance.new("TextLabel")
fpsLabel.Parent = frame
fpsLabel.Size = UDim2.new(1, -16, 1, 0)
fpsLabel.Position = UDim2.new(0, 8, 0, 0)
fpsLabel.Font = Enum.Font.GothamBold
fpsLabel.TextSize = 16
fpsLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
fpsLabel.BackgroundTransparency = 1
fpsLabel.TextXAlignment = Enum.TextXAlignment.Left
fpsLabel.TextStrokeTransparency = 0.3
fpsLabel.Text = "FPS: --  |  Cynx MAX"

-- FPS tracking with longer update interval (1s instead of 0.5s)
local frameCount = 0
local lastUpdate = tick()
local lastFps = 0
local lastColor = Color3.fromRGB(0, 255, 100)

RunService.RenderStepped:Connect(function()
    frameCount = frameCount + 1
    local now = tick()
    local elapsed = now - lastUpdate

    -- Update display every 1 second (was 0.5s — reduces string ops by 50%)
    if elapsed >= 1.0 then
        local fps = math.floor(frameCount / elapsed)
        frameCount = 0
        lastUpdate = now

        -- Only update text if FPS changed (avoid unnecessary property writes)
        if fps ~= lastFps then
            lastFps = fps
            fpsLabel.Text = string.format("FPS: %d  | By Cynx2502", fps)

            local newColor
            if fps >= 50 then
                newColor = Color3.fromRGB(0, 255, 100)
            elseif fps >= 30 then
                newColor = Color3.fromRGB(240, 240, 0)
            else
                newColor = Color3.fromRGB(255, 50, 50)
            end
            
            if newColor ~= lastColor then
                lastColor = newColor
                fpsLabel.TextColor3 = newColor
            end
        end
    end
end)

-- ═══════════════════════════════════════════════════════════
--  APPLY OPTIMIZATIONS
-- ═══════════════════════════════════════════════════════════

optimizeGraphics()

-- Re-apply when character respawns (some games reset settings)
Player.CharacterAdded:Connect(function()
    task.wait(2)
    optimizeGraphics()
end)

-- ═══════════════════════════════════════════════════════════
--  EXECUTOR STATUS CHECK (optimized — write every 5s instead of 3s)
-- ═══════════════════════════════════════════════════════════

getgenv().StopUpdate = false

GuiService.ErrorMessageChanged:Connect(function()
    local Code = GuiService:GetErrorCode().Value
    if Code >= Enum.ConnectionError.DisconnectErrors.Value then
        getgenv().StopUpdate = true
    end
end)

repeat task.wait(0.5) until game.JobId ~= nil

local function writeExecutorStatus(status)
    local username = Player.Name
    pcall(function()
        writefile("executor_check_" .. username .. ".txt", status .. ":" .. os_time)
    end)
end

writeExecutorStatus("working")

coroutine.wrap(function()
    while task.wait(5) do  -- Was 3s, now 5s — reduce file I/O by 40%
        if not getgenv().StopUpdate and Player and Player:FindFirstChild("PlayerScripts") then
            writeExecutorStatus("working")
        end
    end
end)()
